# =============================================================================
# Rise Bridge — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# --- Backend Bridge API ---
# Go backend base URL (no trailing slash)
BRIDGE_API_URL=http://127.0.0.1:8080
# API key for X-API-Key header (shared secret with backend)
BRIDGE_API_KEY=

# --- LayerZero Scan API ---
# LZ Scan API base URL for message tracking (no trailing slash)
LZ_SCAN_API_TESTNET=https://scan-testnet.layerzero-api.com/v1
LZ_SCAN_API_MAINNET=https://scan.layerzero-api.com/v1

# --- LayerZero Scan Base URL (frontend) ---
NEXT_PUBLIC_LZ_SCAN_BASE=https://testnet.layerzeroscan.com

# --- RPC URLs ---
# Sepolia RPC (comma-separated for fallback)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# RISE Testnet RPC
NEXT_PUBLIC_RISE_RPC_URL=https://testnet.riselabs.xyz

# --- Block Explorers ---
NEXT_PUBLIC_RISE_EXPLORER_URL=https://explorer.testnet.riselabs.xyz
